{
  "type": "excalidraw",
  "version": 2,
  "source": "github-copilot",
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 40,
      "y": 30,
      "width": 760,
      "height": 70,
      "text": "DEV-LATCH / final box reveal card",
      "fontSize": 28,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "id": "box_face",
      "type": "rectangle",
      "x": 50,
      "y": 130,
      "width": 280,
      "height": 180,
      "strokeColor": "#1864ab",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "id": "box_text",
      "type": "text",
      "x": 70,
      "y": 150,
      "width": 240,
      "height": 130,
      "text": "Player face\n- central sealed object\n- visible latches/handle\n- clear not-yet state\n- no-force label in fiction",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "id": "build_box",
      "type": "rectangle",
      "x": 370,
      "y": 130,
      "width": 300,
      "height": 180,
      "strokeColor": "#e67700",
      "backgroundColor": "#fff3bf",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "id": "build_text",
      "type": "text",
      "x": 390,
      "y": 150,
      "width": 260,
      "height": 130,
      "text": "Hidden build\n- latch alignment\n- hinge stop\n- manual staff release\n- transport lock\n- pinch clearance",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "id": "recover_box",
      "type": "rectangle",
      "x": 50,
      "y": 360,
      "width": 620,
      "height": 120,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "id": "recover_text",
      "type": "text",
      "x": 70,
      "y": 380,
      "width": 580,
      "height": 80,
      "text": "Reset/recovery: relock photo, staff release path, post-run latch swap, hinge/screw pouch. C5 if box blocks finale or safe exit path; fail on false open, jam, pinch, or hidden state.",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "textAlign": "left",
      "verticalAlign": "top"
    }
  ],
  "appState": { "viewBackgroundColor": "#ffffff" }
}
