    {"id":"sim_text","type":"text","x":650,"y":470,"width":510,"height":125,"text":"Simulator fields\nCriticality: C4 when required clue path depends on it\nBuild time: 2-4 hr\nReplacement min: 2\nSpare qty: 1 overlay/card set\nFailure mode: glare / scratch / swapped overlay","fontSize":16,"fontFamily":1,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":1,"opacity":100,"angle":0,"seed":4022,"version":1,"versionNonce":4022,"isDeleted":false,"groupIds":[],"boundElements":null,"updated":1,"link":null,"locked":false,"textAlign":"left","verticalAlign":"top"}
