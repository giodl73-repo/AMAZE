    {"id":"build_note","type":"text","x":455,"y":310,"width":300,"height":75,"text":"Prototype: acetate + foamcore.\nPublic: matte acrylic/polycarbonate.\nAdd corner keys, sleeve storage, and duplicate printed card.","fontSize":14,"fontFamily":1,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":1,"opacity":100,"angle":0,"seed":4011,"version":1,"versionNonce":4011,"isDeleted":false,"groupIds":[],"boundElements":null,"updated":1,"link":null,"locked":false,"textAlign":"left","verticalAlign":"top"},
