    {"id":"ops_note","type":"text","x":845,"y":305,"width":315,"height":70,"text":"Staff must see whether the overlay is home, clean, and correctly oriented. Camera view should not rely on tiny marks.","fontSize":14,"fontFamily":1,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":1,"opacity":100,"angle":0,"seed":4018,"version":1,"versionNonce":4018,"isDeleted":false,"groupIds":[],"boundElements":null,"updated":1,"link":null,"locked":false,"textAlign":"left","verticalAlign":"top"},
    {"id":"failure_panel","type":"rectangle","x":40,"y":455,"width":545,"height":165,"strokeColor":"#D13438","backgroundColor":"#FDE7E9","fillStyle":"hachure","strokeWidth":2,"roughness":1,"opacity":100,"angle":0,"seed":4019,"version":1,"versionNonce":4019,"isDeleted":false,"groupIds":[],"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},
    {"id":"failure_text","type":"text","x":60,"y":470,"width":505,"height":125,"text":"Failure paths to test\n- REL-SENSORY: glare, tiny marks, low-light dependence\n- REL-STATE: orientation ambiguous\n- REL-RESET: overlay left in wrong sleeve\n- CHAOS-SWAP: similar overlays exchanged\n- Social risk: one player blocks the window","fontSize":16,"fontFamily":1,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":1,"opacity":100,"angle":0,"seed":4020,"version":1,"versionNonce":4020,"isDeleted":false,"groupIds":[],"boundElements":null,"updated":1,"link":null,"locked":false,"textAlign":"left","verticalAlign":"top"},
