    {
      "id": "compare_text",
      "type": "text",
      "x": 65,
      "y": 530,
      "width": 1090,
      "height": 135,
      "text": "Score/build comparison from simulation\nFull Manor: 91.3 avg build hours, 110 slow build, score 87, premium delight + mechanical gating.\nManor-lite: 39.1 avg build hours, 45 slow build, score 87, less delight but better spatial/safety clarity.\nPrototype question: do players describe the lite board as a physical verdict or as placing cards on a board?",
      "fontSize": 18,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
