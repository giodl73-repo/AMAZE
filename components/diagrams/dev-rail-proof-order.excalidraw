    {"id":"failure_text","type":"text","x":60,"y":470,"width":505,"height":125,"text":"Failure paths to test\n- REL-JAM: tile wedges or release sticks\n- REL-LOSS: tile pocketed / under clutter\n- REL-FP: wrong order releases proof\n- REL-SOUP: too many tiles become rummage\n- CHAOS-DUMP: all loose pieces dumped","fontSize":16,"fontFamily":1,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":1,"opacity":100,"angle":0,"seed":5023,"version":1,"versionNonce":5023,"isDeleted":false,"groupIds":[],"boundElements":null,"updated":1,"link":null,"locked":false,"textAlign":"left","verticalAlign":"top"},
