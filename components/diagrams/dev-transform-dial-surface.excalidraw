{
  "type": "excalidraw",
  "version": 2,
  "source": "github-copilot",
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 40,
      "y": 30,
      "width": 760,
      "height": 70,
      "text": "DEV-FOLD / DEV-DIAL transform and tuning surface",
      "fontSize": 28,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "id": "action_box",
      "type": "rectangle",
      "x": 50,
      "y": 130,
      "width": 280,
      "height": 180,
      "strokeColor": "#1864ab",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "id": "action_text",
      "type": "text",
      "x": 70,
      "y": 150,
      "width": 240,
      "height": 130,
      "text": "Player action\n- rotate/fold/tune with one hand\n- large index marks\n- obvious not-yet state\n- no load-bearing use",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "id": "mechanism_box",
      "type": "rectangle",
      "x": 370,
      "y": 130,
      "width": 300,
      "height": 180,
      "strokeColor": "#e67700",
      "backgroundColor": "#fff3bf",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "id": "mechanism_text",
      "type": "text",
      "x": 390,
      "y": 150,
      "width": 260,
      "height": 130,
      "text": "Hidden build\n- hinge/track/stops\n- detent or index mark\n- set-screw knob\n- pinch/force guard\n- staff bypass mark",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "textAlign": "left",
      "verticalAlign": "top"
    },
    {
      "id": "ops_box",
      "type": "rectangle",
      "x": 50,
      "y": 360,
      "width": 620,
      "height": 120,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "roundness": { "type": 3 }
    },
    {
      "id": "ops_text",
      "type": "text",
      "x": 70,
      "y": 380,
      "width": 580,
      "height": 80,
      "text": "Reset/recovery: start mark photo, no-load script, spare knob/hardware, staff compass/tuned-state bypass. Failure modes: latch jam, loosened knob, fine-tune drift, unsafe lean.",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "textAlign": "left",
      "verticalAlign": "top"
    }
  ],
  "appState": { "viewBackgroundColor": "#ffffff" }
}
